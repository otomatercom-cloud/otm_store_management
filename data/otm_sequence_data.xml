<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_otm_purchase" model="ir.sequence">
            <field name="name">Otomater Purchase</field>
            <field name="code">otm.purchase</field>
            <field name="prefix">PUR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_otm_stock_receipt" model="ir.sequence">
            <field name="name">Otomater Stock Receipt (GRN)</field>
            <field name="code">otm.stock.receipt</field>
            <field name="prefix">GRN/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_otm_stock_transfer" model="ir.sequence">
            <field name="name">Otomater Stock Transfer</field>
            <field name="code">otm.stock.transfer</field>
            <field name="prefix">TRF/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_otm_stock_issue" model="ir.sequence">
            <field name="name">Otomater Stock Issue</field>
            <field name="code">otm.stock.issue</field>
            <field name="prefix">ISS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_otm_stock_return" model="ir.sequence">
            <field name="name">Otomater Stock Return</field>
            <field name="code">otm.stock.return</field>
            <field name="prefix">RET/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_otm_stock_adjustment" model="ir.sequence">
            <field name="name">Otomater Stock Adjustment</field>
            <field name="code">otm.stock.adjustment</field>
            <field name="prefix">ADJ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>

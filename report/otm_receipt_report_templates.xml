<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_otm_stock_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Goods Receipt Note</h2>
                        <div class="row mt-3 mb-3">
                            <div class="col-6">
                                <strong>GRN No.:</strong> <span t-field="doc.name"/><br/>
                                <strong>Store:</strong> <span t-field="doc.store_id.name"/><br/>
                                <strong>Vendor:</strong> <span t-field="doc.vendor_id.name"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Received Date:</strong> <span t-field="doc.received_date"/><br/>
                                <strong>Invoice No.:</strong> <span t-field="doc.invoice_number"/><br/>
                                <strong>Received By:</strong> <span t-field="doc.received_by.name"/>
                            </div>
                        </div>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Batch</th>
                                    <th>Expiry</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Purchase Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-field="line.product_tmpl_id.name"/></td>
                                    <td><span t-field="line.batch_number"/></td>
                                    <td><span t-field="line.expiry_date"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end"><span t-field="line.purchase_price"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="row mt-5">
                            <div class="col-4 text-center">Received By</div>
                            <div class="col-4 text-center">Store Manager</div>
                            <div class="col-4 text-center">Authorized Signatory</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

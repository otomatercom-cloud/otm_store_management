<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_otm_stock_receipt" model="ir.actions.report">
        <field name="name">Goods Receipt Note</field>
        <field name="model">otm.stock.receipt</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">otm_store_management.report_otm_stock_receipt_document</field>
        <field name="report_file">otm_store_management.report_otm_stock_receipt_document</field>
        <field name="print_report_name">'GRN - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_otm_stock_receipt"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_otm_stock_transfer" model="ir.actions.report">
        <field name="name">Transfer Slip</field>
        <field name="model">otm.stock.transfer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">otm_store_management.report_otm_stock_transfer_document</field>
        <field name="report_file">otm_store_management.report_otm_stock_transfer_document</field>
        <field name="print_report_name">'Transfer Slip - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_otm_stock_transfer"/>
        <field name="binding_type">report</field>
    </record>

</odoo>

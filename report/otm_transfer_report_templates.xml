<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_otm_stock_transfer_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Internal Transfer Slip</h2>
                        <div class="row mt-3 mb-3">
                            <div class="col-6">
                                <strong>Transfer No.:</strong> <span t-field="doc.name"/><br/>
                                <strong>From Store:</strong> <span t-field="doc.from_store_id.name"/><br/>
                                <strong>To Store:</strong> <span t-field="doc.to_store_id.name"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Transfer Date:</strong> <span t-field="doc.transfer_date"/><br/>
                                <strong>Requested By:</strong> <span t-field="doc.requested_by.name"/><br/>
                                <strong>Reason:</strong> <span t-field="doc.reason"/>
                            </div>
                        </div>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Batch</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-field="line.product_tmpl_id.name"/></td>
                                    <td><span t-field="line.batch_id.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end"><span t-field="line.unit_cost"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="row mt-5">
                            <div class="col-3 text-center">Issued By</div>
                            <div class="col-3 text-center">Approved By</div>
                            <div class="col-3 text-center">Received By</div>
                            <div class="col-3 text-center">Authorized Signatory</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Store Managers only see stores they manage (Inventory Manager / Admin see all). -->
        <record id="rule_otm_store_manager_own_store" model="ir.rule">
            <field name="name">Store Manager: own stores only</field>
            <field name="model_id" ref="model_otm_store"/>
            <field name="domain_force">['|', ('manager_id', '=', user.id), ('manager_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_otm_store_manager'))]"/>
        </record>

        <record id="rule_otm_inventory_manager_all_stores" model="ir.rule">
            <field name="name">Inventory Manager: all stores</field>
            <field name="model_id" ref="model_otm_store"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_otm_inventory_manager'))]"/>
        </record>

        <!-- Department Managers only see their own issues / returns. -->
        <record id="rule_otm_issue_own_department" model="ir.rule">
            <field name="name">Department Manager: own issues only</field>
            <field name="model_id" ref="model_otm_stock_issue"/>
            <field name="domain_force">[('employee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_otm_department_manager'))]"/>
        </record>

        <!-- Auditors: global read-only, no domain restriction. -->
        <record id="rule_otm_auditor_all_moves" model="ir.rule">
            <field name="name">Auditor: full ledger visibility</field>
            <field name="model_id" ref="model_otm_stock_move"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_otm_auditor'))]"/>
        </record>

    </data>
</odoo>

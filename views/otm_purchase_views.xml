<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_purchase_list" model="ir.ui.view">
        <field name="name">otm.purchase.list</field>
        <field name="model">otm.purchase</field>
        <field name="arch" type="xml">
            <list string="Purchases" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="store_id"/>
                <field name="purchase_type"/>
                <field name="purchase_date"/>
                <field name="grand_total" widget="monetary"/>
                <field name="bill_attachment_count" string="Bill" widget="badge"
                       decoration-success="bill_attachment_count &gt; 0"
                       decoration-warning="bill_attachment_count == 0"
                       optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'received'"
                       decoration-info="state == 'confirmed'"
                       decoration-muted="state in ('draft', 'cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_otm_purchase_form" model="ir.ui.view">
        <field name="name">otm.purchase.form</field>
        <field name="model">otm.purchase</field>
        <field name="arch" type="xml">
            <form string="Purchase">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('confirmed', 'cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state not in ('draft', 'confirmed')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,received"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_receipts" type="object" class="oe_stat_button" icon="fa-truck"
                                invisible="receipt_count == 0">
                            <field name="receipt_count" widget="statinfo" string="Receipts"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="vendor_id"/>
                            <field name="store_id"/>
                            <field name="purchase_type"/>
                            <field name="is_interstate" invisible="purchase_type != 'gst'"/>
                        </group>
                        <group>
                            <field name="invoice_number"/>
                            <field name="purchase_date"/>
                            <field name="bill_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_tmpl_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="unit_price"/>
                                    <field name="selling_price"/>
                                    <field name="gst_percent"/>
                                    <field name="taxable_amount" readonly="1"/>
                                    <field name="cgst_amount" readonly="1"/>
                                    <field name="sgst_amount" readonly="1"/>
                                    <field name="igst_amount" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Totals">
                            <group>
                                <group>
                                    <field name="bill_amount" readonly="1"/>
                                    <field name="cgst_amount" readonly="1"/>
                                    <field name="sgst_amount" readonly="1"/>
                                    <field name="igst_amount" readonly="1"/>
                                    <field name="cess_amount"/>
                                </group>
                                <group>
                                    <field name="discount"/>
                                    <field name="freight"/>
                                    <field name="other_charges"/>
                                    <field name="grand_total" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Purchase Bill">
                            <field name="bill_attachment_ids" widget="many2many_binary"
                                   string="Upload the vendor's invoice/bill (photo or scan) — multiple files allowed."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_otm_purchase_search" model="ir.ui.view">
        <field name="name">otm.purchase.search</field>
        <field name="model">otm.purchase</field>
        <field name="arch" type="xml">
            <search string="Purchases">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="store_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group>
                    <filter string="Vendor" name="group_vendor" context="{'group_by': 'vendor_id'}"/>
                    <filter string="Store" name="group_store" context="{'group_by': 'store_id'}"/>
                    <filter string="Purchase Type" name="group_type" context="{'group_by': 'purchase_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_otm_purchase" model="ir.actions.act_window">
        <field name="name">Purchases</field>
        <field name="res_model">otm.purchase</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_otm_purchase_search"/>
    </record>

</odoo>

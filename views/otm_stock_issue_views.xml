<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_stock_issue_list" model="ir.ui.view">
        <field name="name">otm.stock.issue.list</field>
        <field name="model">otm.stock.issue</field>
        <field name="arch" type="xml">
            <list string="Stock Issues" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="store_id"/>
                <field name="department"/>
                <field name="employee_id"/>
                <field name="issue_date"/>
                <field name="total_cost" widget="monetary"/>
                <field name="state" widget="badge" decoration-success="state == 'issued'"/>
            </list>
        </field>
    </record>

    <record id="view_otm_stock_issue_form" model="ir.ui.view">
        <field name="name">otm.stock.issue.form</field>
        <field name="model">otm.stock.issue</field>
        <field name="arch" type="xml">
            <form string="Stock Issue">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_issue" type="object" string="Issue" class="btn-primary"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled', 'issued')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,issued"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="store_id"/>
                            <field name="department"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="reason"/>
                            <field name="approved_by" readonly="1" invisible="not approved_by"/>
                            <field name="issued_by" readonly="1" invisible="not issued_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="state in ('issued', 'cancelled')">
                                <list editable="bottom">
                                    <field name="product_tmpl_id"/>
                                    <field name="batch_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="unit_cost"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_cost" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_otm_stock_issue_search" model="ir.ui.view">
        <field name="name">otm.stock.issue.search</field>
        <field name="model">otm.stock.issue</field>
        <field name="arch" type="xml">
            <search string="Stock Issues">
                <field name="name"/>
                <field name="store_id"/>
                <field name="department"/>
                <group>
                    <filter string="Store" name="group_store" context="{'group_by': 'store_id'}"/>
                    <filter string="Department" name="group_dept" context="{'group_by': 'department'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_otm_stock_issue" model="ir.actions.act_window">
        <field name="name">Stock Issues</field>
        <field name="res_model">otm.stock.issue</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_otm_stock_issue_search"/>
    </record>

</odoo>

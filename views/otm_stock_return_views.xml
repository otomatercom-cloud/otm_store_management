<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_otm_stock_return_list" model="ir.ui.view">
        <field name="name">otm.stock.return.list</field>
        <field name="model">otm.stock.return</field>
        <field name="arch" type="xml">
            <list string="Stock Returns" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="store_id"/>
                <field name="department"/>
                <field name="return_date"/>
                <field name="state" widget="badge" decoration-success="state == 'received'"/>
            </list>
        </field>
    </record>

    <record id="view_otm_stock_return_form" model="ir.ui.view">
        <field name="name">otm.stock.return.form</field>
        <field name="model">otm.stock.return</field>
        <field name="arch" type="xml">
            <form string="Stock Return">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_receive" type="object" string="Receive" class="btn-primary"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled', 'received')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,received"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="store_id"/>
                            <field name="source_issue_id"/>
                            <field name="department"/>
                        </group>
                        <group>
                            <field name="return_date"/>
                            <field name="reason"/>
                            <field name="approved_by" readonly="1" invisible="not approved_by"/>
                            <field name="received_by" readonly="1" invisible="not received_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="state in ('received', 'cancelled')">
                                <list editable="bottom">
                                    <field name="product_tmpl_id"/>
                                    <field name="batch_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="unit_cost"/>
                                    <field name="condition"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_otm_stock_return_search" model="ir.ui.view">
        <field name="name">otm.stock.return.search</field>
        <field name="model">otm.stock.return</field>
        <field name="arch" type="xml">
            <search string="Stock Returns">
                <field name="name"/>
                <field name="store_id"/>
                <group>
                    <filter string="Store" name="group_store" context="{'group_by': 'store_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_otm_stock_return" model="ir.actions.act_window">
        <field name="name">Stock Returns</field>
        <field name="res_model">otm.stock.return</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_otm_stock_return_search"/>
    </record>

</odoo>
